# ==========================================
# CyberSentinel - Variabili di Configurazione
# ==========================================

# PocketBase
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# AbuseIPDB
# Ottieni la chiave da: https://www.abuseipdb.com/api
VITE_ABUSEIPDB_API_KEY=your_api_key_here

# OpenCVE (opzionale)
# VITE_OPENCVE_API_KEY=your_api_key_here

# Polling
# Intervallo in minuti (default: 5)
VITE_POLLING_INTERVAL_MINUTES=5

# Environment
# development | production
VITE_ENV=development
